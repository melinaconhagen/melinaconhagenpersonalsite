  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Source+Sans+3:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #F5F0E8;
      --sand: #E8DFD0;
      --bark: #A0856A;
      --clay: #7A5C44;
      --espresso: #3B2A1F;
      --warm-white: #FAF7F2;
      --muted: #9C8878;
      --border: #DDD4C4;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; background: var(--warm-white); color: var(--espresso); font-weight: 300; line-height: 1.7; }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(250,247,242,0.96); backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      padding: 1rem 3rem;
    }
    .nav-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 500; color: var(--espresso); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: 0.78rem; font-weight: 400;
      color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s;
    }
    .nav-links a:hover, .nav-links a.active-link { color: var(--clay); }

    /* SECTIONS */
    section { display: none; }
    section.active { display: block; }

    /* HERO */
    .hero {
      min-height: calc(100vh - 57px);
      display: flex; align-items: center; justify-content: center;
      padding: 4rem 2rem;
      background: linear-gradient(150deg, var(--cream) 0%, var(--warm-white) 65%);
    }
    .hero-inner { max-width: 680px; text-align: center; }
    .avatar {
      width: 108px; height: 108px; border-radius: 50%;
      background: var(--bark); display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--cream);
      margin: 0 auto 2rem; border: 3px solid var(--sand);
    }
    .hero-inner h1 { font-family: 'Playfair Display', serif; font-size: 2.9rem; font-weight: 400; color: var(--espresso); line-height: 1.15; margin-bottom: 0.4rem; }
    .hero-inner .subtitle { font-size: 0.88rem; color: var(--bark); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 1.8rem; font-weight: 400; }
    .hero-inner .bio { font-size: 1rem; color: var(--muted); max-width: 540px; margin: 0 auto 2rem; line-height: 1.85; }
    .pills { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 2.5rem; }
    .pill { padding: 0.28rem 0.85rem; background: var(--sand); border-radius: 20px; font-size: 0.78rem; color: var(--clay); font-weight: 400; }
    .hero-btns { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
    .btn { display: inline-block; padding: 0.58rem 1.4rem; border-radius: 4px; text-decoration: none; font-size: 0.84rem; font-weight: 400; letter-spacing: 0.05em; transition: all 0.2s; cursor: pointer; border: none; font-family: 'Source Sans 3', sans-serif; }
    .btn-primary { background: var(--clay); color: var(--cream); }
    .btn-primary:hover { background: var(--espresso); }
    .btn-outline { background: transparent; color: var(--clay); border: 1px solid var(--bark); }
    .btn-outline:hover { background: var(--sand); }

    /* PAGE LAYOUT */
    .page { max-width: 760px; margin: 0 auto; padding: 4rem 2rem 6rem; }
    .page-header { margin-bottom: 2.8rem; padding-bottom: 1.4rem; border-bottom: 1px solid var(--border); }
    .page-header h2 { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 400; margin-bottom: 0.25rem; }
    .page-header p { color: var(--muted); font-size: 0.88rem; }

    /* TIMELINE */
    .timeline { display: flex; flex-direction: column; }
    .timeline-item { display: grid; grid-template-columns: 130px 1px 1fr; gap: 0 1.4rem; padding-bottom: 2.6rem; }
    .timeline-item:last-child { padding-bottom: 0; }
    .t-date { text-align: right; padding-top: 0.1rem; }
    .t-date .yr { font-size: 0.78rem; color: var(--bark); font-weight: 400; letter-spacing: 0.03em; line-height: 1.5; }
    .t-date .loc { font-size: 0.72rem; color: var(--muted); margin-top: 0.15rem; }
    .t-line { position: relative; background: var(--border); width: 1px; }
    .t-line::before {
      content: ''; position: absolute; top: 5px; left: 50%; transform: translateX(-50%);
      width: 9px; height: 9px; border-radius: 50%; background: var(--bark); border: 2px solid var(--warm-white);
    }
    .t-body { padding-top: 0; }
    .t-body h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 500; color: var(--espresso); margin-bottom: 0.1rem; }
    .t-body .role { font-size: 0.82rem; color: var(--bark); font-style: italic; margin-bottom: 0.7rem; }
    .t-body ul { list-style: none; padding: 0; }
    .t-body ul li { font-size: 0.88rem; color: var(--muted); padding: 0.18rem 0 0.18rem 1rem; position: relative; line-height: 1.65; }
    .t-body ul li::before { content: '—'; position: absolute; left: 0; color: var(--border); }
    .badge { display: inline-block; padding: 0.14rem 0.6rem; background: var(--cream); border: 1px solid var(--border); border-radius: 3px; font-size: 0.73rem; color: var(--bark); margin-bottom: 0.55rem; }
    .section-label { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--bark); font-weight: 400; margin: 3rem 0 1.6rem; padding-bottom: 0.45rem; border-bottom: 1px solid var(--border); }

    /* CONTACT */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.4rem; }
    .c-card { background: var(--cream); border: 1px solid var(--border); border-radius: 8px; padding: 1.3rem 1.4rem; }
    .c-card .label { font-size: 0.68rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.35rem; }
    .c-card a { color: var(--clay); text-decoration: none; font-size: 0.92rem; }
    .c-card a:hover { text-decoration: underline; }
    .c-card p { color: var(--espresso); font-size: 0.92rem; }
    .c-note { background: var(--sand); border-radius: 8px; padding: 1.3rem 1.4rem; font-size: 0.88rem; color: var(--muted); line-height: 1.75; }

    /* RESPONSIVE */
    @media (max-width: 600px) {
      nav { padding: 0.9rem 1.2rem; }
      .nav-links { gap: 1rem; }
      .hero-inner h1 { font-size: 2.1rem; }
      .timeline-item { grid-template-columns: 85px 1px 1fr; gap: 0 1rem; }
      .contact-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
